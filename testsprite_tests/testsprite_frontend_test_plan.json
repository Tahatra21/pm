[
  {
    "id": "TC001",
    "title": "Register a new user successfully and get redirected to Login",
    "description": "Verifies a new user can register with valid details, sees a success confirmation, and is redirected to the login page.",
    "category": "User Registration",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Register\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"new.user.e2e.001@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Fill \"ValidPassword123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Fill \"ValidPassword123!\" into the confirm password field"
      },
      {
        "type": "action",
        "description": "Click the \"Register\" button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify text indicating registration success is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      }
    ]
  },
