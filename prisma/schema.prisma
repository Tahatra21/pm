generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model integrations {
  id        String  @id
  task_id   String
  platform  String
  link      String
  pr_status String? @default("open")
  tasks     tasks   @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "integrations_task_id_tasks_id_fk")
}

model project_members {
  id         String   @id
  project_id String
  user_id    String
  projects   projects @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_members_project_id_projects_id_fk")
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "project_members_user_id_users_id_fk")
}

model projects {
  id              String            @id
  title           String
  description     String?           @default("")
  color           String?           @default("#6366f1")
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  updated_at      DateTime          @default(now()) @db.Timestamp(6)
  project_members project_members[]
  tasks           tasks[]
}

model sessions {
  id         String   @id
  user_id    String
  token      String   @unique(map: "sessions_token_unique")
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "sessions_user_id_users_id_fk")
}

model tasks {
  id           String         @id
  project_id   String
  title        String
  description  String?        @default("")
  status       String         @default("todo")
  priority     String         @default("medium")
  assignee_id  String?
  due_date     DateTime?      @db.Timestamp(6)
  start_date   DateTime?      @db.Timestamp(6)
  tags         String?
  git_link     String?
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime       @default(now()) @db.Timestamp(6)
  integrations integrations[]
  users        users?         @relation(fields: [assignee_id], references: [id], onUpdate: NoAction, map: "tasks_assignee_id_users_id_fk")
  projects     projects       @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tasks_project_id_projects_id_fk")
}

model users {
  id              String            @id
  name            String
  email           String            @unique(map: "users_email_unique")
  password_hash   String
  role            String            @default("member")
  avatar          String?           @default("")
  color           String?           @default("#6366f1")
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  updated_at      DateTime          @default(now()) @db.Timestamp(6)
  project_members project_members[]
  sessions        sessions[]
  tasks           tasks[]
}
